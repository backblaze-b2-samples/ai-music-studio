# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=YOUR_KEY_ID_HERE
# B2_APPLICATION_KEY=K001_EXAMPLE_NOT_A_REAL_KEY_xxxxxxxxxxxx
# B2_BUCKET_NAME=my-app-uploads

# Optional: if your bucket is configured for public access, set the base URL
# below so the API returns directly-renderable URLs alongside object metadata.
# B2_PUBLIC_URL=https://example.cdn/my-bucket

# Music generation provider (required).
# Only `musicapi` is supported. MusicAPI is a Suno-compatible REST API
# that issues free credits on signup with no card. Get a key at
# https://musicapi.ai — paste it into MUSICAPI_API_KEY below.
MUSIC_PROVIDER=musicapi
MUSICAPI_API_KEY=your_musicapi_api_key

# Default duration (seconds) for new generation requests when the client
# doesn't supply one. Currently advisory — MusicAPI's Sonic endpoint
# returns clips of a model-determined length; the field is kept so a
# future duration-honoring provider can use it.
MUSIC_PROVIDER_DEFAULT_DURATION_SEC=30

# Optional API auth. Leave empty for local single-user development; set in
# shared deployments and send `Authorization: Bearer <token>` from clients.
STUDIO_AUTH_TOKEN=
STUDIO_DEFAULT_OWNER_ID=local

# Cost guard for generation requests: 5 per client per 60 seconds by default.
GENERATION_RATE_LIMIT_CAPACITY=5
GENERATION_RATE_LIMIT_WINDOW_SEC=60

# Optional stem splitter command. Use `{input}` and `{output}` placeholders;
# the command should write vocals.wav, drums.wav, bass.wav, and/or other.wav.
# STEM_SPLITTER_COMMAND=demucs-wrapper --input {input} --output {output}
STEM_SPLITTER_COMMAND=
