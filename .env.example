# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=YOUR_KEY_ID_HERE
# B2_APPLICATION_KEY=K001_EXAMPLE_NOT_A_REAL_KEY_xxxxxxxxxxxx
# B2_BUCKET_NAME=my-app-uploads

# Optional: if your bucket is configured for public access, set the base URL
# below so the API returns directly-renderable URLs alongside object metadata.
# B2_PUBLIC_URL=https://example.cdn/my-bucket

# Music generation provider (required, default: mock)
# - `mock`  — returns a pre-baked WAV from services/api/app/repo/_mock_tracks/.
#             Runs end-to-end with zero external creds. Default.
# - `suno`  — not yet implemented; raises NotImplementedError.
MUSIC_PROVIDER=mock

# Default duration (seconds) for new generation requests when the client
# doesn't supply one.
MUSIC_PROVIDER_DEFAULT_DURATION_SEC=30

# Required only when MUSIC_PROVIDER=suno (placeholder — Suno provider is
# currently a stub).
# SUNO_API_KEY=your_suno_api_key
